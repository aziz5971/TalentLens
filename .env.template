# ============================================================
# TalentLens – Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# Heuristic mode works without any API keys.
# ============================================================

# ── LLM Provider ──────────────────────────────────────────────
# Provide at least one LLM key (OpenAI recommended for speed)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM to use: "openai" or "anthropic"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# ── Verification APIs (optional) ─────────────────────────────
# These improve company/identity verification accuracy
OPENCORPORATES_API_KEY=
CREDLY_CLIENT_ID=
HUNTER_API_KEY=

# ── Scoring Weights ──────────────────────────────────────────
# Must sum to 100. Adjust per role type.
WEIGHT_REQUIRED_SKILLS=35
WEIGHT_PREFERRED_SKILLS=15
WEIGHT_EXPERIENCE=25
WEIGHT_EDUCATION=10
WEIGHT_CERTIFICATIONS=10
WEIGHT_SEMANTIC=5
